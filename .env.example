# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Redis Configuration (Optional - for distributed rate limiting)
# If not provided, will fall back to in-memory rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# App Configuration
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Email (Resend) — REQUIRED for sending invoices, proposals, and team invites.
# Without RESEND_API_KEY every outbound send fails ("Failed to send invoice").
# The sending domain (default send.hazardos.app, or a per-tenant verified domain)
# MUST be verified in Resend or sends are rejected.
RESEND_API_KEY=your-resend-api-key-here
# Verifies Resend delivery/open/bounce webhooks; fails closed in production.
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret-here

# Logging Configuration
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# CORS Configuration (Optional)
# Comma-separated list of allowed origins for internal API routes
# In development, localhost origins are automatically allowed
# In production, NEXT_PUBLIC_APP_URL is always allowed
# Add additional origins here (e.g., admin dashboard on different domain)
# CORS_ALLOWED_ORIGINS=https://admin.your-domain.com,https://partner.your-domain.com

# Sentry Error Tracking (Optional)
# Get your DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_DSN=https://your-dsn@sentry.io/project-id
# For source map uploads (optional, for better stack traces in production)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token